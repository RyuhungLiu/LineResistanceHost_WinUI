<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LineResistanceHost.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource GlassPanelBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource SubtlePanelStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
            <Setter Property="Height" Value="72" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextLineBounds" Value="Tight" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextLineBounds" Value="Tight" />
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PinBadgeStyle" TargetType="Border">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="4,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{ThemeResource PinDisconnectedBrush}" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootLayout" Background="Transparent">
        <InfoBar
            x:Name="StatusBar"
            IsOpen="False"
            Visibility="Collapsed" />

        <ListView
            x:Name="LogList"
            Height="0"
            Visibility="Collapsed" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="14,8,14,14" Spacing="10">
                <Border x:Name="TotalCard" CornerRadius="8" Height="166" BorderBrush="{ThemeResource GlassPanelStrokeBrush}" BorderThickness="1">
                    <Grid>
                        <Image Source="Assets/acrylic-noise.png" Stretch="Fill" Opacity="0.34" IsHitTestVisible="False" />
                        <Border Background="{ThemeResource GlassPanelSubtleBrush}" Opacity="0.2" />
                        <Grid Padding="18,16" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE95E;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" />
                                <TextBlock x:Name="BusResistanceTitleText" Text="总线阻" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" />
                                <TextBlock Text="VBUS + GBUS" FontSize="12" Foreground="{ThemeResource OnGlassSecondaryTextBrush}" VerticalAlignment="Center" Margin="4,2,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                                <TextBlock x:Name="TotalText" Text="0" FontSize="76" FontWeight="Bold" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" TextLineBounds="Tight" />
                                <TextBlock x:Name="TotalUnitText" Text="mΩ" FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource OnGlassSecondaryTextBrush}" VerticalAlignment="Bottom" TextLineBounds="Tight" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="VBUS" Style="{StaticResource MetricLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock x:Name="VbusText" Text="0" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock x:Name="VbusUnitText" Text="mΩ" VerticalAlignment="Bottom" TextLineBounds="Tight" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="GBUS" Style="{StaticResource MetricLabelStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock x:Name="GbusText" Text="0" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock x:Name="GbusUnitText" Text="mΩ" VerticalAlignment="Bottom" TextLineBounds="Tight" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CableLengthLabelText" Text="线材长度" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center" />
                        <Slider x:Name="LengthSlider" Grid.Column="1" Minimum="0.3" Maximum="3" StepFrequency="0.1" Value="1" ValueChanged="LengthSlider_ValueChanged" />
                        <TextBlock x:Name="LengthText" Grid.Column="2" Text="1.0 m" FontWeight="SemiBold" MinWidth="52" TextAlignment="Right" VerticalAlignment="Center" />
                        <TextBlock x:Name="ThresholdText" Visibility="Collapsed" />
                    </Grid>
                </Border>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="4*" />
                    </Grid.ColumnDefinitions>

                    <Border Height="96" Style="{StaticResource GlassCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8EF;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                <TextBlock x:Name="CableSectionTitleText" Text="线材" Style="{StaticResource SectionTitleStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock x:Name="CableTypeLabelText" Text="类型" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="CableText" Text="未连接" FontSize="25" FontWeight="SemiBold" TextLineBounds="Tight" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Height="96" Style="{StaticResource GlassCardStyle}">
                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8A7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                <TextBlock x:Name="PinContinuityTitleText" Text="引脚通断" Style="{StaticResource SectionTitleStyle}" />
                            </StackPanel>
                            <Grid Grid.Row="1" ColumnSpacing="5" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DpBadge" Style="{StaticResource PinBadgeStyle}"><TextBlock x:Name="DpText" Text="DP 断" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" /></Border>
                                <Border x:Name="DmBadge" Grid.Column="1" Style="{StaticResource PinBadgeStyle}"><TextBlock x:Name="DmText" Text="DM 断" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" /></Border>
                                <Border x:Name="C1Badge" Grid.Column="2" Style="{StaticResource PinBadgeStyle}"><TextBlock x:Name="C1Text" Text="C1 断" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" /></Border>
                                <Border x:Name="C2Badge" Grid.Column="3" Style="{StaticResource PinBadgeStyle}"><TextBlock x:Name="C2Text" Text="C2 断" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" /></Border>
                                <Border x:Name="S1Badge" Grid.Column="4" Style="{StaticResource PinBadgeStyle}"><TextBlock x:Name="S1Text" Text="S1 断" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" /></Border>
                                <Border x:Name="S2Badge" Grid.Column="5" Style="{StaticResource PinBadgeStyle}"><TextBlock x:Name="S2Text" Text="S2 断" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource OnGlassPrimaryTextBrush}" /></Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8FD;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                            <TextBlock x:Name="RawFrameTitleText" Text="原始帧" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>
                        <TextBox x:Name="RawFrameText" Grid.Column="1" Text="-" FontFamily="Consolas" IsReadOnly="True" TextWrapping="NoWrap" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE950;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                            <TextBlock x:Name="DeviceCaptureTitleText" Text="设备与采集" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>

                        <TextBlock x:Name="ConnectionText" Visibility="Collapsed" />

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                x:Name="DeviceComboBox"
                                Header="目标 HID 设备"
                                PlaceholderText="未发现设备"
                                DisplayMemberPath="DisplayName"
                                HorizontalAlignment="Stretch" />
                            <ToggleSwitch
                                x:Name="AutoConnectSwitch"
                                Grid.Column="1"
                                Header="抢占"
                                IsOn="True" />
                            <StackPanel Grid.Column="2" Spacing="3" VerticalAlignment="Bottom">
                                <TextBlock x:Name="FrameCountLabelText" Text="帧数" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="FrameCountText" Text="0" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="3" VerticalAlignment="Bottom">
                                <TextBlock x:Name="ChecksumLabelText" Text="校验" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ChecksumText" Text="等待" FontSize="16" FontWeight="SemiBold" TextWrapping="NoWrap" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="RefreshButton" Style="{StaticResource CommandButtonStyle}" Click="RefreshButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                    <TextBlock x:Name="RefreshButtonText" Text="刷新" />
                                </StackPanel>
                            </Button>
                            <Button
                                x:Name="ConnectButton"
                                Grid.Column="1"
                                MinHeight="34"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="ConnectButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8CE;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                    <TextBlock x:Name="ConnectButtonText" Text="连接" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ActivateButton" Grid.Column="2" Style="{StaticResource CommandButtonStyle}" Click="ActivateButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE945;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                    <TextBlock x:Name="ActivateButtonText" Text="激活" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DisconnectButton" Grid.Row="1" Style="{StaticResource CommandButtonStyle}" Click="DisconnectButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE711;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                    <TextBlock x:Name="DisconnectButtonText" Text="断开" />
                                </StackPanel>
                            </Button>
                            <ToggleButton x:Name="HoldButton" Grid.Row="1" Grid.Column="1" MinHeight="34" HorizontalAlignment="Stretch" Checked="HoldButton_Toggled" Unchecked="HoldButton_Toggled">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE769;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                    <TextBlock Text="Hold" />
                                </StackPanel>
                            </ToggleButton>
                            <Button Grid.Row="1" Grid.Column="2" MinHeight="34" HorizontalAlignment="Stretch" Click="SampleButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE7C3;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                                    <TextBlock x:Name="SampleFrameButtonText" Text="模拟帧" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassCardStyle}">
                    <Grid ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.ColumnSpan="2" Spacing="2" VerticalAlignment="Center">
                            <TextBlock x:Name="AppearanceTitleText" Text="外观" Style="{StaticResource SectionTitleStyle}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="BackdropComboBox"
                            Grid.Row="1"
                            Header="背景材质"
                            SelectedIndex="0"
                            SelectionChanged="BackdropComboBox_SelectionChanged"
                            HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Desktop Acrylic" Tag="Acrylic" />
                            <ComboBoxItem Content="Mica" Tag="Mica" />
                            <ComboBoxItem Content="Mica Alt" Tag="MicaAlt" />
                            <ComboBoxItem Content="None" Tag="None" />
                        </ComboBox>
                        <ToggleSwitch
                            x:Name="ThemeSwitch"
                            Grid.Row="1"
                            Grid.Column="1"
                            Header="深色模式"
                            OffContent="关"
                            OnContent="开"
                            Toggled="ThemeSwitch_Toggled" />
                        <ComboBox
                            x:Name="LanguageComboBox"
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Header="语言"
                            SelectionChanged="LanguageComboBox_SelectionChanged"
                            HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="简体中文" Tag="SimplifiedChinese" />
                            <ComboBoxItem Content="繁體中文" Tag="TraditionalChinese" />
                            <ComboBoxItem Content="English" Tag="English" />
                        </ComboBox>
                    </Grid>
                </Border>

                <HyperlinkButton
                    Content="WinUI Fork From https://oa1.ruaorz.com/"
                    NavigateUri="https://oa1.ruaorz.com/"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Padding="4,0,4,2" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
